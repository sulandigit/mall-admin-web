    "nprogress": "^0.2.0",
    "pinia": "^2.1.7",
    "sass": "^1.69.5",
    "vue": "^3.3.8",
    "vue-router": "^4.2.5",
    "@vueuse/core": "^10.5.0"
  },
  "devDependencies": {
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "@vitejs/plugin-vue": "^4.4.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
